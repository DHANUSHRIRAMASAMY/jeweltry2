rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Anyone can read jewelry items (public catalog)
    match /jewelry/{itemId} {
      allow read: if true;
      // Only authenticated shop owners can write their own items
      allow create: if request.auth != null
        && request.resource.data.shopOwnerId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.shopOwnerId == request.auth.uid;
    }
  }
}
